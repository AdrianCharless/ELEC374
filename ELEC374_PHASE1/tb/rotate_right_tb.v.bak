// ============================================================================
// Rotate Right Testbench
// Tests the rotate_right module with various test cases
// ============================================================================

`timescale 1ns/10ps

module rotate_right_tb;

    // Testbench signals
    reg [31:0] A;
    reg [31:0] count;
    wire [31:0] Result;
    
    // Test counter
    integer test_num;
    integer errors;

    // Instantiate the rotate_right module
    rotate_right dut (
        .A(A),
        .count(count),
        .Result(Result)
    );

    // Test procedure
    initial begin
        // Initialize
        test_num = 0;
        errors = 0;
        
        $display("========================================");
        $display("Rotate Right Test Bench");
        $display("========================================");
        
        // Test 1: Rotate by 0 (should return original value)
        test_num = test_num + 1;
        A = 32'hA5A5A5A5;
        count = 32'd0;
        #10;
        if (Result !== 32'hA5A5A5A5) begin
            $display("ERROR Test %0d: Rotate by 0 failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'hA5A5A5A5, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 0", test_num);
        end
        
        // Test 2: Rotate by 1
        test_num = test_num + 1;
        A = 32'b10101010101010101010101010101010;
        count = 32'd1;
        #10;
        if (Result !== 32'b01010101010101010101010101010101) begin
            $display("ERROR Test %0d: Rotate by 1 failed", test_num);
            $display("  Input: %b", A);
            $display("  Expected: %b", 32'b01010101010101010101010101010101);
            $display("  Got:      %b", Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 1", test_num);
        end
        
        // Test 3: Rotate by 4
        test_num = test_num + 1;
        A = 32'hDEADBEEF;
        count = 32'd4;
        #10;
        if (Result !== 32'hFDEADBEE) begin
            $display("ERROR Test %0d: Rotate by 4 failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'hFDEADBEE, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 4", test_num);
        end
        
        // Test 4: Rotate by 8
        test_num = test_num + 1;
        A = 32'h12345678;
        count = 32'd8;
        #10;
        if (Result !== 32'h78123456) begin
            $display("ERROR Test %0d: Rotate by 8 failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'h78123456, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 8", test_num);
        end
        
        // Test 5: Rotate by 16 (half word)
        test_num = test_num + 1;
        A = 32'hABCD1234;
        count = 32'd16;
        #10;
        if (Result !== 32'h1234ABCD) begin
            $display("ERROR Test %0d: Rotate by 16 failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'h1234ABCD, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 16", test_num);
        end
        
        // Test 6: Rotate by 31
        test_num = test_num + 1;
        A = 32'b10000000000000000000000000000000;
        count = 32'd31;
        #10;
        if (Result !== 32'b00000000000000000000000000000001) begin
            $display("ERROR Test %0d: Rotate by 31 failed", test_num);
            $display("  Input: %b", A);
            $display("  Expected: %b", 32'b00000000000000000000000000000001);
            $display("  Got:      %b", Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 31", test_num);
        end
        
        // Test 7: Rotate by 32 (full rotation, should return original)
        test_num = test_num + 1;
        A = 32'hCAFEBABE;
        count = 32'd32;
        #10;
        if (Result !== 32'hCAFEBABE) begin
            $display("ERROR Test %0d: Rotate by 32 failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'hCAFEBABE, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Rotate by 32 (full rotation)", test_num);
        end
        
        // Test 8: Large count value (only lower 5 bits matter)
        test_num = test_num + 1;
        A = 32'h0000000F;
        count = 32'd37; // Same as count = 5 (37 mod 32 = 5)
        #10;
        if (Result !== 32'h80000000) begin
            $display("ERROR Test %0d: Large count value failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'h80000000, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Large count value (37 → 5)", test_num);
        end
        
        // Test 9: All ones pattern
        test_num = test_num + 1;
        A = 32'hFFFFFFFF;
        count = 32'd7;
        #10;
        if (Result !== 32'hFFFFFFFF) begin
            $display("ERROR Test %0d: All ones rotate failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'hFFFFFFFF, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: All ones pattern", test_num);
        end
        
        // Test 10: All zeros pattern
        test_num = test_num + 1;
        A = 32'h00000000;
        count = 32'd12;
        #10;
        if (Result !== 32'h00000000) begin
            $display("ERROR Test %0d: All zeros rotate failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'h00000000, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: All zeros pattern", test_num);
        end
        
        // Test 11: Single bit set at position 0
        test_num = test_num + 1;
        A = 32'h00000001;
        count = 32'd1;
        #10;
        if (Result !== 32'h80000000) begin
            $display("ERROR Test %0d: Single bit rotate failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'h80000000, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Single bit rotation", test_num);
        end
        
        // Test 12: Pattern 0x55555555 rotate by 2
        test_num = test_num + 1;
        A = 32'h55555555;
        count = 32'd2;
        #10;
        if (Result !== 32'h55555555) begin
            $display("ERROR Test %0d: Pattern rotate by 2 failed", test_num);
            $display("  Input: %h, Count: %0d, Expected: %h, Got: %h", 
                     A, count, 32'h55555555, Result);
            errors = errors + 1;
        end else begin
            $display("PASS Test %0d: Pattern 0x55555555 rotate by 2", test_num);
        end
        
        // Print summary
        $display("========================================");
        if (errors == 0) begin
            $display("ALL TESTS PASSED! (%0d/%0d)", test_num, test_num);
        end else begin
            $display("TESTS COMPLETED: %0d PASSED, %0d FAILED", test_num - errors, errors);
        end
        $display("========================================");
        
        $finish;
    end

endmodule
